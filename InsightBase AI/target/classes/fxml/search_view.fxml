<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.insightbaseai.controller.SearchController">
   <top>
      <VBox spacing="10.0">
         <children>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Document Search" />
            <Separator />
            
            <!-- Search Controls -->
            <VBox spacing="10.0">
               <children>
                  <!-- Main Search Bar -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label text="Search:" />
                        <TextField fx:id="searchField" promptText="Enter search terms..." prefWidth="300.0" 
                                 style="-fx-font-size: 14px;" />
                        <Button fx:id="searchButton" onAction="#handleSearch" text="Search" 
                              style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
                        <Button fx:id="clearButton" onAction="#handleClear" text="Clear" />
                     </children>
                  </HBox>
                  
                  <!-- Search Options -->
                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <Label text="Mode:" />
                        <ComboBox fx:id="searchModeCombo" prefWidth="120.0" />
                        <Separator orientation="VERTICAL" />
                        <CheckBox fx:id="caseSensitiveCheck" text="Case Sensitive" />
                        <CheckBox fx:id="wholeWordsCheck" text="Whole Words" />
                        <Separator orientation="VERTICAL" />
                        <Button onAction="#handleAdvancedSearch" text="Advanced..." />
                     </children>
                  </HBox>
                  
                  <!-- Progress and Status -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <ProgressBar fx:id="searchProgressBar" prefWidth="200.0" visible="false" />
                        <Label fx:id="searchStatusLabel" text="Ready" style="-fx-text-fill: #666;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="resultsCountLabel" style="-fx-font-weight: bold;" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
         </padding>
      </VBox>
   </top>
   
   <center>
      <SplitPane dividerPositions="0.6" orientation="HORIZONTAL">
         <items>
            <!-- Search Results Table -->
            <VBox>
               <children>
                  <Label style="-fx-font-weight: bold;" text="Search Results" />
                  <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Document Name" />
                        <TableColumn fx:id="typeColumn" prefWidth="60.0" text="Type" />
                        <TableColumn fx:id="sizeColumn" prefWidth="80.0" text="Size" />
                        <TableColumn fx:id="relevanceColumn" prefWidth="80.0" text="Relevance" />
                     </columns>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="5.0" top="10.0" />
               </padding>
            </VBox>
            
            <!-- Document Content Display -->
            <VBox>
               <children>
                  <Label style="-fx-font-weight: bold;" text="Document Content" />
                  <TextArea fx:id="selectedDocumentContent" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                          promptText="Select a document from search results to view its content..."
                          style="-fx-font-family: monospace;" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="5.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f5f5f5;">
         <children>
            <Label text="💡 Tip: Use quotation marks for exact phrases, or try different search modes for better results." 
                   style="-fx-text-fill: #666; -fx-font-style: italic;" />
         </children>
         <padding>
            <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>